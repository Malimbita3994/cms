# Copy to cms/.env on the production server and fill in real values.

APP_NAME="Portfolio CMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://cms.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Trust reverse proxy (nginx, Cloudflare, load balancer)
TRUSTED_PROXIES=*

CMS_SITE_API_CACHE_SECONDS=300
CMS_NOTIFICATION_CACHE_SECONDS=60
CMS_DASHBOARD_CACHE_SECONDS=300

OCTANE_SERVER=frankenphp
OCTANE_WORKERS=4
OCTANE_MAX_REQUESTS=500
OCTANE_MAX_EXECUTION_TIME=60

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Production database (required for Octane multi-worker)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=portfolio_cms
DB_USERNAME=portfolio
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Path to Next.js public/ (uploads). Required when CMS is not in ../public relative to this app.
PORTFOLIO_DISK_ROOT=D:/web/public

# Public Next.js site (CMS triggers cache revalidation after saves)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_REVALIDATE_SECRET=change-me-to-a-long-random-string
PORTFOLIO_ASSET_BASE_URL=https://yourdomain.com

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional: restrict admin panel to office IP at nginx; still change default admin password after seed.
